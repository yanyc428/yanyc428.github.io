/vendor/
.bundle/

# Ignore folders related to IDEs
.vscode/

# Ignore files created by MacOS
.DS_Store

# Local preview artifacts (not for GitHub Pages)
_site/
_config_local.yml
.preview_tmp/
Gemfile.local
Gemfile.local.lock
preview.sh
